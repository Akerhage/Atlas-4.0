{
  "name": "atlas",
  "version": "4.0.0",
  "description": "AI-driven kundtjänstassistent för trafikskolor",
  "private": true,
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npm run electron",
    "electron": "chcp 65001 && electron .",
    "playwright:server": "node playwright/mock-server.js",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:e2e:headed": "playwright test --config=playwright.config.js --headed",
    "test:e2e:ui": "playwright test --config=playwright.config.js --ui",
    "setversion": "node tests/scripts/set_version.js",
    "gitpush": "node tests/scripts/git-push.js",
    "agenttest": "node tests/scripts/test_agent.js",
    "test": "node tests/scripts/test_runner.js",
    "sessiondebug": "node tests/scripts/session-debug.js",
    "stress": "node tests/scripts/atlas-master-test.js",
    "arendetest": "node tests/scripts/test-simulator.js",
    "generatequestions": "node tests/scripts/fix_generate_test_questions.js",
    "cleanstate": "node tests/scripts/fix_cleanstate.js",
    "bigbang": "node tests/scripts/fix_bigbang.js",
    "seed:offices": "node tests/scripts/fix_seed_offices.js",
    "seed:users": "node tests/scripts/fix_seed_users.js",
    "backupdb": "node tests/scripts/fix_backup_manager.js",
    "restoredb": "node tests/scripts/fix_restore_db_manager.js",
    "basfakta": "node tests/scripts/audit_basfakta.js",
    "tree": "node tests/scripts/audit_tree.js",
    "syntax": "node tests/scripts/audit_syntax_check.js",
    "audit:all": "node tests/scripts/audit_1_server_db_renderer.js && node tests/scripts/audit_2_server_engines.js && node tests/scripts/audit_3_server_package_db_main.js && node tests/scripts/audit_4_renderer_html_css.js",
    "audit:report": "node tests/scripts/audit_collect_results.js",
    "audit:1": "node tests/scripts/audit_1_server_db_renderer.js",
    "audit:2": "node tests/scripts/audit_2_server_engines.js",
    "audit:3": "node tests/scripts/audit_3_server_package_db_main.js",
    "audit:4": "node tests/scripts/audit_4_renderer_html_css.js",
    "audit:db": "node tests/scripts/audit_db.js",
    "manual1": "node tests/scripts/audit_create_manual.js",
    "manual2": "node tests/scripts/audit_create_manual2.js",
    "manual3": "node tests/scripts/audit_create_manual3.js",
    "audit:diagnose": "node tests/scripts/audit_diagnose.js",
    "audit:server": "node tests/scripts/audit_server.js",
    "audit:backend": "node tests/scripts/audit_backend.js",
    "audit:balance": "node tests/scripts/audit_check_balance.js",
    "clean:dist": "rimraf dist build dist-client",
    "rebuild": "npm run clean:dist && npm run build:win",
    "build:win": "electron-builder --win",
    "build:client": "npm run clean:dist && electron-builder --win --config electron-builder-client.json",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -mwl",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop atlas",
    "pm2:logs": "pm2 logs atlas",
    "pm2:restart": "pm2 restart atlas",
    "qa": "node tests/scripts/qa-test-runner.js",
    "qa2": "node tests/scripts/qa-test-runner-v2.js",
    "qa3": "node tests/scripts/qa-test-runner-v3.js",
    "qa4": "node tests/scripts/qa-test-runner-v4.js",
    "ragdebug": "node tests/scripts/rag-debug.js",
    "resetdb": "node tests/scripts/fix_reset_all_clean_restart.js",
    "review": "node tests/scripts/atlas_review.js",
    "audit:roles": "node tests/scripts/audit-roles.js",
    "stress:arende": "node tests/scripts/test-stress-arende.js"
  },
  "keywords": [
    "trafikskola",
    "ai",
    "assistant"
  ],
  "author": "Patrik Åkerhage",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@octokit/rest": "^22.0.1",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "child_process": "^1.0.2",
    "clipboardy": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.0",
    "imap-simple": "^5.1.0",
    "inquirer": "^8.2.7",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.1",
    "minisearch": "^7.2.0",
    "multer": "^2.0.2",
    "ngrok": "^5.0.0-beta.2",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.12",
    "openai": "^4.104.0",
    "pdfkit": "^0.17.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "electron": "^39.1.2",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.1.2"
  },
  "build": {
    "appId": "com.mydrivingacademy.atlas",
    "productName": "Atlas Trafikskola",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ngrok/**/*",
      "**/node_modules/sqlite3/**/*",
      "**/node_modules/bcrypt/**/*"
    ],
    "extraResources": [
      {
        "from": "knowledge/",
        "to": "knowledge/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "atlas.db",
        "to": "atlas.db"
      },
      {
        "from": "patch/",
        "to": "patch/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "config.json",
        "to": "config.json"
      },
      {
        "from": "ngrok.exe",
        "to": "ngrok.exe"
      }
    ],
    "files": [
      "main.js",
      "server.js",
      "db.js",
      "preload.js",
      "preload-loader.js",
      "package.json",
      "routes/**/*",
      "middleware/**/*",
      "utils/**/*",
      "Renderer/**/*",
      "node_modules/sqlite3/**/*",
      "node_modules/bcrypt/**/*",
      "node_modules/jsonwebtoken/**/*",
      "node_modules/express/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "Renderer/assets/icons/app/icon.ico"
    }
  }
}
